# ============================================================
# CRM UtopIA — Variables de entorno
# Copiar este archivo a .env.local y completar los valores
# NUNCA commitear .env.local (ya está en .gitignore)
# ============================================================

# ---------- WhatsApp Business API (Meta) ----------
# Obtener en: https://developers.facebook.com → tu app → WhatsApp → Configuración de la API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Cadena random que vos inventás (ej: utopia-webhook-2026-xY9kP3mLqR)
WHATSAPP_VERIFY_TOKEN=

# ---------- Telegram Bot API ----------
# 1. En Telegram, hablale a @BotFather → /newbot → nombre + username → guardás el token
# 2. Pegá el token acá (formato 1234567890:AAAA...)
TELEGRAM_BOT_TOKEN=
# Opcional pero recomendado: cadena random para validar que los webhooks vienen de Telegram
# Si lo seteás, también lo pasás cuando configures el webhook con setWebhook
TELEGRAM_WEBHOOK_SECRET=

# ---------- Supabase ----------
# Obtener en: https://supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ service_role: SOLO servidor, nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=

# ---------- OpenRouter (modelo IA) ----------
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
# Modelo de visión usado para describir imágenes (debe soportar input de imágenes)
VISION_MODEL=openai/gpt-4o-mini

# ---------- OpenAI (solo para Whisper — transcripción de audios) ----------
# Opcional: si no la configurás, los audios se guardan sin transcribir.
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---------- Resend (envío de emails) ----------
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=
# Tu email donde llegan las alertas de leads HOT y el digest diario
NOTIFY_EMAIL=
# Remitente. Mientras no verifiques dominio propio, dejar onboarding@resend.dev
RESEND_FROM=onboarding@resend.dev

# ---------- Auth / Seguridad ----------
# Email(s) autorizados al dashboard, separados por coma
ALLOWED_EMAILS=
# Cadena random para autenticar los crons de Vercel (inventar)
CRON_SECRET=

# Solo necesario en modo dev de Meta + números argentinos (gotcha de la allowlist).
# Formato: wa_id=outbound_format,wa_id2=outbound_format2
# Borrar/dejar vacío cuando publiques la app.
WHATSAPP_RECIPIENT_OVERRIDES=
